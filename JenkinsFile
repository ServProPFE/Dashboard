pipeline{
    agent{
        docker{
            image 'node:22-alpine'
            args '-u root --workdir /app'
        }
    }
    stages{  
        stage('Install Dependencies'){
            steps{
                echo 'Installing dependencies...'
                bat 'npm install'
            }
        }
        stage('Dockerisation'){
            steps{
                echo 'Dockerising the application...'
                // Add Dockerisation steps here
                bat 'docker compose up -d'
            }
        }
    }
}